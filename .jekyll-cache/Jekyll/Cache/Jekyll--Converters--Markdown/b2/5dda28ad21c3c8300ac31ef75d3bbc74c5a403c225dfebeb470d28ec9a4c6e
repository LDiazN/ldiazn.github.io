<span class="err">ô </span> <span class="err">ô ô </span><span class="k">pub</span> <span class="k">fn</span> <span class="nf">new</span><span class="p">(</span><span class="o">&amp;</span><span class="k">mut</span> <span class="k">self</span><span class="p">,</span> <span class="n">element</span><span class="p">:</span> <span class="n">T</span><span class="p">)</span> <span class="k">-&gt;</span> <span class="n">EntityPtr</span><span class="o">&lt;</span><span class="n">T</span><span class="o">&gt;</span> <span class="p">{</span>
<span class="err">ô </span> <span class="err">ô </span> <span class="err">ô </span> <span class="err">ô ô </span><span class="k">if</span> <span class="k">self</span><span class="py">.free</span><span class="nf">.is_empty</span><span class="p">()</span> <span class="p">{</span>
